<Window x:Class="LightStickyNote.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:LightStickyNote.App.ViewModels"
        mc:Ignorable="d"
        Title="Light Sticky Note"
        Icon="Assets/AppIcon.png"
        Width="360"
        Height="620"
        MinWidth="310"
        MinHeight="360"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        AllowsTransparency="True"
        Background="Transparent"
        FontFamily="Microsoft YaHei UI"
        UseLayoutRounding="True"
        Topmost="{Binding Settings.AlwaysOnTop}">
    <Window.Resources>
        <SolidColorBrush x:Key="TextBrush" Color="#DCE7FF" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#8494B4" />
        <SolidColorBrush x:Key="AccentBrush" Color="#91B5FF" />
        <SolidColorBrush x:Key="CardBrush" Color="#B2192332" />
        <SolidColorBrush x:Key="CardBorderBrush" Color="#462F405D" />

        <Style x:Key="HeaderProgressBarStyle" TargetType="ProgressBar">
            <Setter Property="Background" Value="#3925354B" />
            <Setter Property="Foreground" Value="#91B5FF" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid x:Name="PART_Track">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="2" />
                            <Border x:Name="PART_Indicator"
                                    HorizontalAlignment="Left"
                                    Background="{TemplateBinding Foreground}"
                                    CornerRadius="2" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="#441D293B" />
            <Setter Property="BorderBrush" Value="#4B4E6791" />
            <Setter Property="Foreground" Value="#BBD0FF" />
            <Setter Property="Cursor" Value="SizeAll" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="9">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#66324A70" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#997FA6EA" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#88405D8C" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TaskCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Width" Value="18" />
            <Setter Property="Height" Value="18" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="CheckBorder"
                                Width="16"
                                Height="16"
                                Background="#321C2A3D"
                                BorderBrush="#936E91C7"
                                BorderThickness="1"
                                CornerRadius="5">
                            <TextBlock x:Name="CheckGlyph"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Text="✓"
                                       Foreground="#BFD3FF"
                                       FontFamily="Segoe UI Symbol"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       Visibility="Collapsed" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckBorder" Property="Background" Value="#73527BBB" />
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="#CC91B5FF" />
                                <Setter TargetName="CheckGlyph" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="#E6A8C3FF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TaskEditorStyle" TargetType="TextBox">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Padding" Value="2,1" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="AcceptsReturn" Value="True" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsDone}" Value="True">
                    <Setter Property="TextDecorations" Value="Strikethrough" />
                    <Setter Property="Foreground" Value="#63718B" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DeleteButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="25" />
            <Setter Property="Height" Value="25" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="#8494B4" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="Visibility" Value="Collapsed" />
            <Setter Property="ToolTip" Value="删除任务" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="DeleteBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="DeleteBorder" Property="Background" Value="#66324A70" />
                                <Setter TargetName="DeleteBorder" Property="BorderBrush" Value="#997FA6EA" />
                                <Setter Property="Foreground" Value="#D7E5FF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ReminderBadgeStyle" TargetType="Border">
            <Setter Property="Visibility" Value="Collapsed" />
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="Background" Value="#24324A" />
            <Setter Property="BorderBrush" Value="#4E6893" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
        </Style>

        <Style x:Key="TaskMenuButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="27" />
            <Setter Property="Height" Value="27" />
            <Setter Property="Background" Value="#1622333D" />
            <Setter Property="BorderBrush" Value="#00000000" />
            <Setter Property="Foreground" Value="#A9BEE4" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="Visibility" Value="Collapsed" />
            <Setter Property="ToolTip" Value="更多操作" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="TaskMenuButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="9">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TaskMenuButtonBorder" Property="Background" Value="#2F31465B" />
                                <Setter TargetName="TaskMenuButtonBorder" Property="BorderBrush" Value="#668DB4F2" />
                                <Setter Property="Foreground" Value="#E4EEFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="TaskMenuButtonBorder" Property="Background" Value="#48395773" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PolishedReminderBadgeStyle" TargetType="Border">
            <Setter Property="Visibility" Value="Collapsed" />
            <Setter Property="Padding" Value="9,3" />
            <Setter Property="Background" Value="#1D2C42" />
            <Setter Property="BorderBrush" Value="#4D6F9D" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="11" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="TaskMenuContextMenuStyle" TargetType="ContextMenu">
            <Setter Property="Background" Value="#F716202F" />
            <Setter Property="BorderBrush" Value="#6E88B5F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="6" />
            <Setter Property="HasDropShadow" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <StackPanel IsItemsHost="True"
                                        KeyboardNavigation.DirectionalNavigation="Cycle" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TaskMenuItemStyle" TargetType="MenuItem">
            <Setter Property="Foreground" Value="#E7F0FF" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="Margin" Value="0,2,0,2" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="MenuItemBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              ContentSource="Header" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="MenuItemBorder" Property="Background" Value="#2D3850" />
                                <Setter TargetName="MenuItemBorder" Property="BorderBrush" Value="#5E82C0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TaskListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="ScrollViewer.CanContentScroll" Value="False" />
        </Style>

        <Style x:Key="TaskListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DialogButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="68" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Background" Value="#51283A54" />
            <Setter Property="BorderBrush" Value="#76516D98" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#C9D9F8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="DialogButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="DialogButtonBorder" Property="Background" Value="#73405A82" />
                                <Setter TargetName="DialogButtonBorder" Property="BorderBrush" Value="#A783A9E4" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="DialogButtonBorder" Property="Background" Value="#8A4B6996" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerDialogButtonStyle"
               BasedOn="{StaticResource DialogButtonStyle}"
               TargetType="Button">
            <Setter Property="Background" Value="#573C2635" />
            <Setter Property="BorderBrush" Value="#8A6D3C52" />
            <Setter Property="Foreground" Value="#FFB2C0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="DangerButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="DangerButtonBorder" Property="Background" Value="#804B2F41" />
                                <Setter TargetName="DangerButtonBorder" Property="BorderBrush" Value="#B9864C63" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="DangerButtonBorder" Property="Background" Value="#9B5B394D" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingToggleStyle" TargetType="CheckBox">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="18" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="Track"
                                Width="34"
                                Height="16"
                                Background="#3A28364D"
                                BorderBrush="#4D526A91"
                                BorderThickness="1"
                                CornerRadius="8">
                            <Ellipse x:Name="Thumb"
                                     Width="10"
                                     Height="10"
                                     Margin="3,0,0,0"
                                     HorizontalAlignment="Left"
                                     Fill="#8291AC" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#805578BA" />
                                <Setter TargetName="Track" Property="BorderBrush" Value="#A691B5FF" />
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right" />
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,3,0" />
                                <Setter TargetName="Thumb" Property="Fill" Value="#C7D8FF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border BorderBrush="#65455C83"
            BorderThickness="1">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0"
                                 EndPoint="1,1"
                                 Opacity="{Binding Settings.Opacity}">
                <GradientStop Color="#FF111925" Offset="0" />
                <GradientStop Color="#FF0A0F17" Offset="1" />
            </LinearGradientBrush>
        </Border.Background>
        <Grid Margin="14,10,14,14">
            <Grid.RowDefinitions>
                <RowDefinition Height="34" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                  Background="Transparent"
                  MouseLeftButtonDown="Header_OnMouseLeftButtonDown"
                  MouseMove="Header_OnMouseMove"
                  MouseLeftButtonUp="Header_OnMouseLeftButtonUp"
                  LostMouseCapture="Header_OnLostMouseCapture">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock VerticalAlignment="Center"
                                   Text="{Binding PendingCount, StringFormat=还有 {0} 项}"
                                   Foreground="#BFD3FF"
                                   FontSize="12"
                                   FontWeight="Bold" />
                        <TextBlock x:Name="FeedbackTextBlock"
                                   Margin="10,0,0,0"
                                   VerticalAlignment="Center"
                                   Text="{Binding FeedbackText}"
                                   Foreground="#7894A5"
                                   FontSize="11" />
                    </StackPanel>
                    <ProgressBar x:Name="CompletionProgress"
                                 Width="190"
                                 Height="3"
                                 Margin="0,5,0,0"
                                 HorizontalAlignment="Left"
                                 Maximum="100"
                                 Value="{Binding CompletionPercentage, Mode=OneWay}"
                                 Style="{StaticResource HeaderProgressBarStyle}" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal">
                    <Button x:Name="SettingsButton"
                            Margin="0,0,6,0"
                            Click="SettingsButton_OnClick"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="设置">
                        <TextBlock Text="⚙"
                                   FontFamily="Segoe UI Symbol"
                                   FontSize="14" />
                    </Button>
                    <Button Click="HideToTrayButton_OnClick"
                            AutomationProperties.Name="隐藏到托盘"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="隐藏到托盘">
                        <TextBlock Text="×"
                                   FontFamily="Segoe UI"
                                   FontSize="17" />
                    </Button>
                </StackPanel>
            </Grid>

            <Grid x:Name="TaskListHost"
                  Grid.Row="1"
                  Margin="0,12,0,12">
                <Border Background="#24192534"
                        BorderBrush="#363B506F"
                        BorderThickness="1">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Items.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <TextBlock HorizontalAlignment="Center"
                                   Text="今天很轻松"
                                   Foreground="#A7C0F5"
                                   FontSize="14"
                                   FontWeight="Bold" />
                        <TextBlock Margin="0,7,0,0"
                                   HorizontalAlignment="Center"
                                   Text="添加第一条任务，慢慢来"
                                   Foreground="#5E7092"
                                   FontSize="11" />
                    </StackPanel>
                </Border>

                <ScrollViewer x:Name="TaskListScrollViewer"
                              VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="TaskItemsControl"
                                  ItemsSource="{Binding Items}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:TaskItemViewModel}">
                                <Border x:Name="TaskCard"
                                        Margin="0,0,0,8"
                                        Padding="10,8"
                                        Background="{StaticResource CardBrush}"
                                        BorderBrush="{StaticResource CardBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        RenderTransformOrigin="0.5,0.5">
                                    <Border.RenderTransform>
                                        <TransformGroup>
                                            <ScaleTransform ScaleX="{Binding DragScale}"
                                                            ScaleY="{Binding DragScale}" />
                                            <TranslateTransform Y="{Binding DragOffsetY}" />
                                        </TransformGroup>
                                    </Border.RenderTransform>
                                    <DockPanel LastChildFill="True">
                                        <Button x:Name="TaskMenuButton"
                                                DockPanel.Dock="Right"
                                                Width="27"
                                                Height="27"
                                                Margin="8,0,0,0"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Top"
                                                AutomationProperties.Name="删除任务"
                                                Click="TaskMenuButton_OnClick"
                                                Style="{StaticResource TaskMenuButtonStyle}"
                                                ToolTip="更多操作">
                                            <Button.ContextMenu>
                                                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
                                                             Style="{StaticResource TaskMenuContextMenuStyle}">
                                                    <MenuItem Header="{Binding ReminderMenuText}"
                                                              Style="{StaticResource TaskMenuItemStyle}"
                                                              Click="ReminderMenuItem_OnClick" />
                                                    <MenuItem Header="删除任务"
                                                              Style="{StaticResource TaskMenuItemStyle}"
                                                              Click="DeleteMenuItem_OnClick" />
                                                </ContextMenu>
                                            </Button.ContextMenu>
                                            <TextBlock Text="⋮"
                                                       FontFamily="Segoe UI"
                                                       FontSize="16"
                                                       FontWeight="Bold" />
                                        </Button>
                                        <Border x:Name="ReminderBadge"
                                                DockPanel.Dock="Right"
                                                Margin="8,1,0,0"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Top"
                                                Style="{StaticResource PolishedReminderBadgeStyle}">
                                            <TextBlock x:Name="ReminderBadgeText"
                                                       Text="{Binding ReminderDisplayText}"
                                                       Foreground="#D8E7FF"
                                                       FontSize="11"
                                                       FontWeight="SemiBold" />
                                        </Border>
                                        <CheckBox DockPanel.Dock="Left"
                                                  Margin="0,3,9,0"
                                                  VerticalAlignment="Top"
                                                  Checked="TaskCheckBox_OnChecked"
                                                  Unchecked="TaskCheckBox_OnUnchecked"
                                                  IsChecked="{Binding IsDone, UpdateSourceTrigger=PropertyChanged}"
                                                  Style="{StaticResource TaskCheckBoxStyle}" />
                                        <TextBox Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource TaskEditorStyle}" />
                                    </DockPanel>
                                </Border>
                                <DataTemplate.Triggers>
                                    <Trigger SourceName="TaskCard" Property="IsMouseOver" Value="True">
                                        <Setter TargetName="TaskMenuButton" Property="Visibility" Value="Visible" />
                                        <Setter TargetName="TaskMenuButton" Property="Opacity" Value="1" />
                                        <Setter TargetName="ReminderBadge" Property="Visibility" Value="Collapsed" />
                                        <Setter TargetName="TaskCard" Property="BorderBrush" Value="#725A78A8" />
                                    </Trigger>
                                    <DataTrigger Binding="{Binding HasReminder}" Value="True">
                                        <Setter TargetName="ReminderBadge" Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsReminderOverdue}" Value="True">
                                        <Setter TargetName="ReminderBadge" Property="Background" Value="#4A2732" />
                                        <Setter TargetName="ReminderBadge" Property="BorderBrush" Value="#D07A97" />
                                        <Setter TargetName="ReminderBadgeText" Property="Foreground" Value="#FFD1DE" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsDragActive}" Value="True">
                                        <Setter TargetName="TaskCard" Property="Panel.ZIndex" Value="100" />
                                        <Setter TargetName="TaskCard" Property="Opacity" Value="0.99" />
                                        <Setter TargetName="TaskCard" Property="Background">
                                            <Setter.Value>
                                                <LinearGradientBrush StartPoint="0.5,0"
                                                                     EndPoint="0.5,1">
                                                    <GradientStop Color="#F03A4F68"
                                                                  Offset="0" />
                                                    <GradientStop Color="#DC2D3D54"
                                                                  Offset="0.16" />
                                                    <GradientStop Color="#D1263448"
                                                                  Offset="0.52" />
                                                    <GradientStop Color="#C61D2A3A"
                                                                  Offset="1" />
                                                </LinearGradientBrush>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter TargetName="TaskCard" Property="BorderBrush" Value="#B9D4FF" />
                                        <Setter TargetName="TaskCard" Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="36"
                                                                  Opacity="0.68"
                                                                  ShadowDepth="18"
                                                                  Color="#050B14" />
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <Border Grid.Row="2"
                    Padding="11,8"
                    Background="#B2192433"
                    BorderBrush="#5B4A648E"
                    BorderThickness="1"
                    CornerRadius="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Margin="0,-1,9,0"
                               VerticalAlignment="Center"
                               Text="+"
                               Foreground="{StaticResource AccentBrush}"
                               FontFamily="Segoe UI"
                               FontSize="21"
                               FontWeight="Light" />
                    <TextBox x:Name="NewTaskTextBox"
                             Grid.Column="1"
                             VerticalAlignment="Center"
                             Text="{Binding NewTaskText, UpdateSourceTrigger=PropertyChanged}"
                             BorderThickness="0"
                             Background="Transparent"
                             CaretBrush="{StaticResource AccentBrush}"
                             Foreground="{StaticResource TextBrush}"
                             FontSize="13"
                             KeyDown="NewTaskTextBox_OnKeyDown"
                             ToolTip="输入任务后按 Enter 新增" />
                    <TextBlock Grid.Column="2"
                               Margin="8,0,0,0"
                               VerticalAlignment="Center"
                               Text="ENTER"
                               Foreground="#657493"
                               FontFamily="Consolas"
                               FontSize="9" />
                </Grid>
            </Border>

            <Popup x:Name="SettingsPopup"
                   Placement="Bottom"
                   PlacementTarget="{Binding ElementName=SettingsButton}"
                   HorizontalOffset="-174"
                   VerticalOffset="7"
                   AllowsTransparency="True"
                   StaysOpen="False">
                <Border Width="210"
                        Padding="14"
                        Background="#FC101722"
                        BorderBrush="#865772A0"
                        BorderThickness="1"
                        CornerRadius="12">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="18"
                                          Opacity="0.5"
                                          ShadowDepth="4"
                                          Color="#000000" />
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Margin="1,0,0,8"
                                   Text="SYSTEM SETTINGS"
                                   Foreground="#A7C0F5"
                                   FontFamily="Consolas"
                                   FontSize="10"
                                   FontWeight="Bold" />

                        <Grid Height="34">
                            <TextBlock VerticalAlignment="Center"
                                       Text="始终置顶"
                                       Foreground="{StaticResource TextBrush}"
                                       FontSize="12" />
                            <CheckBox HorizontalAlignment="Right"
                                      VerticalAlignment="Center"
                                      IsChecked="{Binding Settings.AlwaysOnTop, UpdateSourceTrigger=PropertyChanged}"
                                      Style="{StaticResource SettingToggleStyle}" />
                        </Grid>

                        <Grid Height="34">
                            <TextBlock VerticalAlignment="Center"
                                       Text="开机自启"
                                       Foreground="{StaticResource TextBrush}"
                                       FontSize="12" />
                            <CheckBox HorizontalAlignment="Right"
                                      VerticalAlignment="Center"
                                      IsChecked="{Binding Settings.LaunchAtStartup, UpdateSourceTrigger=PropertyChanged}"
                                      Style="{StaticResource SettingToggleStyle}" />
                        </Grid>

                        <Grid Height="34">
                            <TextBlock VerticalAlignment="Center"
                                       Text="边缘吸附隐藏"
                                       Foreground="{StaticResource TextBrush}"
                                       FontSize="12" />
                            <CheckBox HorizontalAlignment="Right"
                                      VerticalAlignment="Center"
                                      IsChecked="{Binding Settings.EdgeSnapEnabled, UpdateSourceTrigger=PropertyChanged}"
                                      Style="{StaticResource SettingToggleStyle}" />
                        </Grid>

                        <Grid Height="45"
                              Margin="0,2,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid>
                                <TextBlock Text="透明度"
                                           Foreground="{StaticResource TextBrush}"
                                           FontSize="12" />
                                <TextBlock HorizontalAlignment="Right"
                                           Text="{Binding Settings.Opacity, StringFormat={}{0:P0}}"
                                           Foreground="#91B5FF"
                                           FontFamily="Consolas"
                                           FontSize="11" />
                            </Grid>
                            <Slider Grid.Row="1"
                                    Margin="0,5,0,0"
                                    Minimum="0.45"
                                    Maximum="1"
                                    TickFrequency="0.05"
                                    IsMoveToPointEnabled="True"
                                    Value="{Binding Settings.Opacity, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>

                        <Grid Height="45"
                              Margin="0,5,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid>
                                <TextBlock Text="边签宽度"
                                           Foreground="{StaticResource TextBrush}"
                                           FontSize="12" />
                                <TextBlock HorizontalAlignment="Right"
                                           Text="{Binding Settings.EdgeRevealWidth, StringFormat={}{0:F0} px}"
                                           Foreground="#91B5FF"
                                           FontFamily="Consolas"
                                           FontSize="11" />
                            </Grid>
                            <Slider Grid.Row="1"
                                    Margin="0,5,0,0"
                                    Minimum="2"
                                    Maximum="8"
                                    TickFrequency="1"
                                    IsSnapToTickEnabled="True"
                                    IsMoveToPointEnabled="True"
                                    Value="{Binding Settings.EdgeRevealWidth, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>

                        <Grid Height="24"
                              Margin="0,2,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center"
                                       Text="宽度预览"
                                       Foreground="#6F82A6"
                                       FontSize="10" />
                            <Border Grid.Column="1"
                                    Width="62"
                                    Height="16"
                                    Margin="10,0,0,0"
                                    HorizontalAlignment="Right"
                                    Background="#22172233"
                                    BorderBrush="#353E5678"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                <Grid HorizontalAlignment="Right">
                                    <Rectangle Width="{Binding Settings.EdgeRevealWidth}"
                                               RadiusX="7"
                                               RadiusY="7"
                                               HorizontalAlignment="Right"
                                               Fill="#91B5FF" />
                                </Grid>
                            </Border>
                        </Grid>

                        <Grid Height="45"
                              Margin="0,5,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid>
                                <TextBlock Text="收起延迟"
                                           Foreground="{StaticResource TextBrush}"
                                           FontSize="12" />
                                <TextBlock HorizontalAlignment="Right"
                                           Text="{Binding Settings.EdgeHideDelayMilliseconds, StringFormat={}{0} ms}"
                                           Foreground="#91B5FF"
                                           FontFamily="Consolas"
                                           FontSize="11" />
                            </Grid>
                            <Slider Grid.Row="1"
                                    Margin="0,5,0,0"
                                    Minimum="300"
                                    Maximum="3000"
                                    TickFrequency="100"
                                    IsMoveToPointEnabled="True"
                                    Value="{Binding Settings.EdgeHideDelayMilliseconds, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                    </StackPanel>
                </Border>
            </Popup>

            <Grid x:Name="DeleteConfirmationOverlay"
                  Grid.RowSpan="3"
                  Panel.ZIndex="20"
                  Background="#B20A0F17"
                  Visibility="Collapsed">
                <Border Width="276"
                        Padding="16"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="#F21A2433"
                        BorderBrush="#9B6D85AB"
                        BorderThickness="1"
                        CornerRadius="13">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="22"
                                          Opacity="0.55"
                                          ShadowDepth="5"
                                          Color="#000000" />
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="删除这条任务？"
                                   Foreground="#E5EDFF"
                                   FontSize="14"
                                   FontWeight="Bold" />
                        <TextBlock x:Name="DeleteTaskPreviewTextBlock"
                                   MaxHeight="54"
                                   Margin="0,9,0,0"
                                   TextTrimming="CharacterEllipsis"
                                   TextWrapping="Wrap"
                                   Foreground="#91A4C8"
                                   FontSize="12" />
                        <TextBlock Margin="0,8,0,0"
                                   Text="删除后无法恢复"
                                   Foreground="#D4869A"
                                   FontSize="11" />
                        <StackPanel Margin="0,15,0,0"
                                    HorizontalAlignment="Right"
                                    Orientation="Horizontal">
                            <Button x:Name="CancelDeleteButton"
                                    Margin="0,0,8,0"
                                    Click="CancelDeleteButton_OnClick"
                                    Content="取消"
                                    IsCancel="True"
                                    IsDefault="True"
                                    Style="{StaticResource DialogButtonStyle}" />
                            <Button Click="ConfirmDeleteButton_OnClick"
                                    Content="删除"
                                    Style="{StaticResource DangerDialogButtonStyle}" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <ResizeGrip Grid.RowSpan="3"
                        Width="16"
                        Height="16"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Cursor="SizeNWSE"
                        Foreground="#7187B0" />
        </Grid>
    </Border>
</Window>

